{
  "name": "@unify-js/vitepress-mermaid",
  "version": "1.0.0",
  "description": "VitePress custom theme for Mermaid diagram preview with fullscreen, zoom, and pan support",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": {
      "import": "./dist/style.css"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit",
    "dev": "vite build --watch"
  },
  "keywords": [
    "vitepress",
    "mermaid",
    "diagram",
    "preview",
    "plugin"
  ],
  "author": "Luo Huidong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unify-js/vitepress-mermaid.git"
  },
  "peerDependencies": {
    "mermaid": "^11.0.0",
    "vitepress": "^2.0.0 || ^2.0.0-alpha"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "mermaid": "^11.13.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vitepress": "2.0.0-alpha.16",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6"
  }
}
