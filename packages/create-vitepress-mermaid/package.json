  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unify-js/vitepress-mermaid.git",
    "directory": "packages/create-vitepress-mermaid"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "memfs": "^4.56.11",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
