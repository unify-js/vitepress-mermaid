{
  "name": "@unify-js/create-vitepress-mermaid",
  "version": "1.0.0",
  "description": "CLI to create VitePress projects with vitepress-mermaid",
  "type": "module",
  "bin": {
    "create-vitepress-mermaid": "./dist/cli.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.prod.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "vitepress",
    "mermaid",
    "cli",
    "scaffold",
    "template"
  ],
